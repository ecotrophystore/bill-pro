rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helpers
    function isAuthenticated() {
      return true; // TEMPORARY for verification
    }
    
    function getUserRole() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_active == true
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    
    function isAdmin() {
      return getUserRole() == 'admin';
    }
    
    function isAccounts() {
      return getUserRole() == 'accounts';
    }
    
    function isSales() {
      return getUserRole() == 'sales';
    }
    
    function isUnchanged(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }
    
    function isLocked() {
      return resource != null && resource.data.is_locked == true;
    }

    // 7. Role Isolation: Strict Firestore security rules (Admin override everything)
    
    // USERS COLLECTION
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // CUSTOMERS COLLECTION
    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isAccounts() || isSales();
    }
    
    // PRODUCTS COLLECTION
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isAccounts() || isSales();
    }
    
    // SETTINGS COLLECTION
    match /settings/{docId} {
      allow read: if isAuthenticated();
      // 15. Settings Integrity: Admin-only edits
      allow write: if isAdmin(); 
    }
    
    // QUOTATIONS COLLECTION
    match /quotations/{quotationId} {
      allow read: if isAdmin() || isAccounts() || (isSales() && resource.data.created_by == request.auth.uid);
      allow create: if (isAdmin() || isAccounts() || isSales());
      allow update: if (isAdmin() || isAccounts() || isSales());
      allow delete: if (isAdmin() || isAccounts() || isSales());
    }
    
    // INVOICES COLLECTION
    match /invoices/{invoiceId} {
      allow read: if isAdmin() || isAccounts() || (isSales() && resource.data.created_by == request.auth.uid);
      allow create: if (isAdmin() || isAccounts());
      allow update: if isAdmin() || isAccounts();
      allow delete: if isAdmin() || isAccounts();
    }
    
    // CASH MEMOS COLLECTION
    match /cash_memos/{memoId} {
      allow read: if isAdmin() || isAccounts();
      allow create: if (isAdmin() || isAccounts());
      allow update: if (isAdmin() || isAccounts());
      allow delete: if (isAdmin() || isAccounts());
    }
    
    // PURCHASES COLLECTION
    match /purchases/{purchaseId} {
      allow read: if isAdmin() || isAccounts() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || isAccounts() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || isAccounts() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // PURCHASE ATTACHMENTS
    match /purchase_attachments/{docId} {
      allow read: if isAdmin() || isAccounts() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // AI LEARNING FEEDBACK
    match /ai_learning_feedback/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // AI EXTRACTION LOGS
    match /ai_extraction_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // PURCHASE ACTIVITY LOGS
    match /purchase_activity_logs/{docId} {
      allow read: if isAdmin() || isAccounts() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    
    // TRANSACTIONS COLLECTION (Bank Recon)
    match /transactions/{transactionId} {
      allow read: if isAdmin() || isAccounts();
      allow write: if isAdmin() || isAccounts();
    }
    
    // REPORTS & NOTIFICATIONS
    match /reports/{reportId} { allow read: if isAuthenticated(); }
    match /notifications/{notifId} { 
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid; // for marking read
    }
    
    // AUDIT LOG
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write to audit logs
    }
    
  }
}

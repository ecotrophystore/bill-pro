rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /purchases/uploads/{userId}/{allPaths=**} {
      // Only the uploading user can read/write their own uploads initially
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /purchases/processed/{purchaseId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions can write to processed
    }
  }
}
